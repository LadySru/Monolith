<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content="Monolith Social — A cozy anime & gaming Discord. Est. 2021. Join free."/>
  <meta property="og:title" content="Monolith Social — Anime & Gaming Discord"/>
  <meta property="og:description" content="Anime, gaming, memes, game nights. 213 members. Est. July 2021. Join free."/>
  <meta property="og:image" content="banner.jpg"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <title>Monolith Social</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg:        #08080a;
      --bg2:       #0f0f12;
      --card:      #121215;
      --card-hov:  #18181d;
      --border:    rgba(255,255,255,0.07);
      --border2:   rgba(255,255,255,0.12);
      --teal:      #0df2d4;
      --teal-mid:  #00bfa5;
      --teal-dim:  rgba(13,242,212,0.08);
      --teal-glow: rgba(13,242,212,0.22);
      --amber:     #f5c842;
      --red:       #ff4d6d;
      --green:     #3ddc84;
      --text:      #eeeae0;
      --text2:     #9997a0;
      --text3:     #5a5860;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* ── CURSOR ── */
    #cur {
      width: 10px; height: 10px;
      background: var(--teal);
      border-radius: 50%;
      position: fixed; pointer-events: none; z-index: 9999;
      transform: translate(-50%,-50%);
      transition: width .18s, height .18s, opacity .18s;
      mix-blend-mode: screen;
    }
    body:not(:hover) #cur { opacity: 0; }
    #cur.big { width: 36px; height: 36px; background: transparent; border: 1.5px solid var(--teal); }

    /* ── NOISE ── */
    body::before {
      content: '';
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 40px; height: 64px;
      background: rgba(8,8,10,0.85);
      backdrop-filter: blur(20px) saturate(1.4);
      border-bottom: 1px solid var(--border);
    }
    .nav-left { display: flex; align-items: center; gap: 12px; }
    .nav-av {
      width: 32px; height: 32px; border-radius: 50%;
      object-fit: cover;
      border: 1.5px solid rgba(13,242,212,0.4);
    }
    .nav-name {
      font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1rem;
      color: var(--text); letter-spacing: 0.5px;
    }
    .nav-name span { color: var(--teal); }
    .nav-pill {
      display: flex; align-items: center; gap: 6px;
      background: rgba(61,220,132,0.1);
      border: 1px solid rgba(61,220,132,0.25);
      border-radius: 20px; padding: 4px 12px;
      font-family: 'DM Mono', monospace; font-size: 0.7rem;
      color: var(--green); letter-spacing: 1px;
    }
    .nav-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); animation: pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{box-shadow:0 0 0 0 rgba(61,220,132,.4);} 50%{box-shadow:0 0 0 6px rgba(61,220,132,0);} }
    .nav-right { display: flex; align-items: center; gap: 12px; }
    .nav-ghost {
      font-family: 'DM Mono', monospace; font-size: 0.72rem; letter-spacing: 1px;
      color: var(--text2); text-decoration: none;
      transition: color .2s;
    }
    .nav-ghost:hover { color: var(--text); }
    .nav-cta {
      background: var(--teal); color: #08080a;
      font-family: 'DM Mono', monospace; font-size: 0.72rem; font-weight: 500;
      letter-spacing: 1px; padding: 8px 20px; border-radius: 4px;
      text-decoration: none; transition: opacity .2s, transform .2s;
    }
    .nav-cta:hover { opacity: .88; transform: translateY(-1px); }

    /* ── HERO ── */
    #hero {
      position: relative; min-height: 100vh;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      text-align: center;
      overflow: hidden;
      padding: 80px 24px 60px;
    }

    /* Banner bg */
    .hero-bg {
      position: absolute; inset: 0; z-index: 0;
      background: url('banner.jpg') center/cover no-repeat;
      filter: brightness(.18) saturate(.7);
      transform: scale(1.04);
      animation: bgDrift 18s ease-in-out infinite alternate;
    }
    @keyframes bgDrift { 0%{transform:scale(1.04) translate(0,0);} 100%{transform:scale(1.08) translate(-1%,-1%);} }

    /* gradient vignette */
    .hero-vignette {
      position: absolute; inset: 0; z-index: 1;
      background:
        radial-gradient(ellipse 80% 50% at 50% 60%, transparent 20%, rgba(8,8,10,.7) 80%),
        linear-gradient(180deg, rgba(8,8,10,.4) 0%, rgba(8,8,10,.1) 40%, rgba(8,8,10,.85) 100%);
    }

    .hero-inner {
      position: relative; z-index: 2;
      max-width: 780px; margin: 0 auto;
      display: flex; flex-direction: column; align-items: center; gap: 0;
    }

    /* avatar */
    .hero-av-wrap { position: relative; margin-bottom: 28px; }
    .hero-av {
      width: 96px; height: 96px; border-radius: 50%; object-fit: cover;
      border: 2px solid rgba(13,242,212,.5);
      box-shadow: 0 0 0 6px rgba(13,242,212,.06), 0 0 40px rgba(13,242,212,.14);
      display: block;
    }
    .hero-av-live {
      position: absolute; bottom: 4px; right: 4px;
      width: 16px; height: 16px; border-radius: 50%;
      background: var(--green); border: 2px solid var(--bg);
      animation: pulse 2s ease-in-out infinite;
    }

    /* eyebrow */
    .eyebrow {
      font-family: 'DM Mono', monospace; font-size: 0.68rem;
      letter-spacing: 3px; text-transform: uppercase; color: var(--teal);
      margin-bottom: 16px; opacity: 0; animation: riseIn .7s .1s ease forwards;
    }

    /* headline */
    h1 {
      font-family: 'Syne', sans-serif; font-weight: 800;
      font-size: clamp(3rem, 8vw, 6.5rem);
      line-height: .95; letter-spacing: -2px;
      margin-bottom: 20px; opacity: 0; animation: riseIn .8s .2s ease forwards;
    }
    h1 .line1 { display: block; color: var(--text); }
    h1 .line2 { display: block; color: var(--teal); }

    .hero-tagline {
      font-size: 1.1rem; font-weight: 300; color: var(--text2);
      max-width: 480px; line-height: 1.8;
      margin-bottom: 36px; opacity: 0; animation: riseIn .8s .32s ease forwards;
    }

    @keyframes riseIn { from{opacity:0;transform:translateY(20px);} to{opacity:1;transform:translateY(0);} }

    /* CTA */
    .hero-cta {
      display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;
      margin-bottom: 52px; opacity: 0; animation: riseIn .8s .44s ease forwards;
    }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 9px;
      background: var(--teal); color: #08080a;
      font-family: 'DM Mono', monospace; font-size: 0.82rem; font-weight: 500;
      letter-spacing: 0.5px; padding: 14px 30px; border-radius: 6px;
      text-decoration: none; transition: opacity .2s, transform .2s, box-shadow .2s;
    }
    .btn-primary:hover { opacity: .9; transform: translateY(-2px); box-shadow: 0 8px 28px var(--teal-glow); }
    .btn-outline {
      display: inline-flex; align-items: center; gap: 9px;
      background: transparent; color: var(--text2);
      border: 1px solid var(--border2);
      font-family: 'DM Mono', monospace; font-size: 0.82rem;
      letter-spacing: 0.5px; padding: 14px 30px; border-radius: 6px;
      text-decoration: none; transition: border-color .2s, color .2s, transform .2s;
    }
    .btn-outline:hover { border-color: var(--teal); color: var(--teal); transform: translateY(-2px); }

    /* stats */
    .hero-stats {
      display: flex; align-items: center; gap: 0;
      border: 1px solid var(--border); border-radius: 8px;
      overflow: hidden; opacity: 0; animation: riseIn .8s .58s ease forwards;
    }
    .stat {
      padding: 14px 28px; text-align: center;
      border-right: 1px solid var(--border);
    }
    .stat:last-child { border-right: none; }
    .stat-n {
      font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.5rem;
      color: var(--text); display: block;
    }
    .stat-n.teal { color: var(--teal); }
    .stat-n.green { color: var(--green); }
    .stat-l {
      font-family: 'DM Mono', monospace; font-size: 0.6rem;
      letter-spacing: 2px; color: var(--text3); text-transform: uppercase; margin-top: 2px; display: block;
    }

    /* scroll cue */
    .scroll-cue {
      position: absolute; bottom: 28px; left: 50%; transform: translateX(-50%);
      z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 6px;
      font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 3px;
      color: var(--text3); text-transform: uppercase;
      animation: scrollBob 2.4s ease-in-out infinite;
    }
    .scroll-cue svg { color: var(--teal); }
    @keyframes scrollBob { 0%,100%{transform:translateX(-50%) translateY(0);} 50%{transform:translateX(-50%) translateY(8px);} }

    /* ── SEALS ── */
    #seals {
      position: relative; z-index: 1;
      padding: 28px 40px;
      border-bottom: 1px solid var(--border);
      background: var(--bg2);
    }
    .seals-row {
      max-width: 1100px; margin: 0 auto;
      display: flex; align-items: center; justify-content: center;
      gap: 8px; flex-wrap: wrap;
    }
    .seal {
      display: flex; align-items: center; gap: 8px;
      padding: 8px 16px; border-radius: 20px;
      border: 1px solid var(--border);
      background: var(--card);
      font-family: 'DM Mono', monospace; font-size: 0.68rem;
      color: var(--text2); letter-spacing: .5px;
      transition: border-color .2s, color .2s;
    }
    .seal:hover { border-color: var(--teal); color: var(--text); }
    .seal-i { font-size: .9rem; }

    /* ── SECTION SHARED ── */
    section { position: relative; z-index: 1; }
    .wrap { max-width: 1100px; margin: 0 auto; padding: 0 40px; }
    .section-pad { padding: 96px 0; }

    .label {
      font-family: 'DM Mono', monospace; font-size: 0.62rem;
      letter-spacing: 3px; text-transform: uppercase; color: var(--teal);
      margin-bottom: 14px; display: block;
    }
    h2 {
      font-family: 'Syne', sans-serif; font-weight: 800;
      font-size: clamp(1.8rem, 3.5vw, 3rem);
      line-height: 1.05; letter-spacing: -1px;
      color: var(--text); margin-bottom: 12px;
    }
    h2 em { color: var(--teal); font-style: normal; }
    .sec-sub {
      font-size: 1rem; font-weight: 300; color: var(--text2);
      max-width: 520px; line-height: 1.8;
    }

    /* ── FEATURES ── */
    #features { background: var(--bg); border-top: 1px solid var(--border); }
    .feat-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 1px; background: var(--border);
      border: 1px solid var(--border);
      border-radius: 12px; overflow: hidden;
      margin-top: 52px;
    }
    .feat {
      background: var(--card); padding: 32px 28px;
      transition: background .2s;
      position: relative; overflow: hidden;
    }
    .feat::after {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: var(--fc, var(--teal));
      transform: scaleX(0); transform-origin: left;
      transition: transform .35s ease;
    }
    .feat:hover { background: var(--card-hov); }
    .feat:hover::after { transform: scaleX(1); }
    .feat-icon { font-size: 1.8rem; margin-bottom: 16px; display: block; }
    .feat-title {
      font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1rem;
      color: var(--text); margin-bottom: 8px;
    }
    .feat-body { font-size: .9rem; color: var(--text2); line-height: 1.75; font-weight: 300; }

    /* ── GAMES ── */
    #games { background: var(--bg2); border-top: 1px solid var(--border); }
    .games-header {
      display: flex; align-items: flex-end; justify-content: space-between;
      margin-bottom: 40px; flex-wrap: wrap; gap: 16px;
    }
    .games-grid {
      display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px;
    }
    .game-card {
      position: relative; border-radius: 10px; overflow: hidden;
      aspect-ratio: 2/3; border: 1px solid var(--border);
      background: var(--card);
      transition: transform .3s cubic-bezier(.34,1.56,.64,1), border-color .25s, box-shadow .3s;
      cursor: none;
    }
    .game-card:hover {
      transform: translateY(-10px) scale(1.02);
      border-color: rgba(13,242,212,.4);
      box-shadow: 0 20px 48px rgba(0,0,0,.6), 0 0 0 1px rgba(13,242,212,.15);
    }
    .game-img {
      position: absolute; inset: 0; width: 100%; height: 100%;
      object-fit: cover; transition: transform .4s ease;
    }
    .game-card:hover .game-img { transform: scale(1.06); }
    .game-fb {
      position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
      font-size: 2.5rem;
    }
    .game-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(0deg, rgba(8,8,10,.98) 0%, rgba(8,8,10,.5) 45%, transparent 100%);
      display: flex; flex-direction: column; justify-content: flex-end;
      padding: 14px 12px; opacity: 0; transition: opacity .25s;
    }
    .game-card:hover .game-overlay { opacity: 1; }
    /* always-visible mini label at bottom */
    .game-label {
      position: absolute; bottom: 0; left: 0; right: 0;
      background: linear-gradient(0deg, rgba(8,8,10,.95) 0%, transparent 100%);
      padding: 24px 12px 10px;
    }
    .game-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: .75rem; color: var(--text); line-height: 1.3; }
    .game-genre { font-family: 'DM Mono', monospace; font-size: .6rem; color: var(--teal); letter-spacing: 1px; margin-top: 3px; }
    .g1{background:linear-gradient(160deg,#1a0808,#300)}
    .g2{background:linear-gradient(160deg,#080816,#14143a)}
    .g3{background:linear-gradient(160deg,#001a18,#003530)}
    .g4{background:linear-gradient(160deg,#071a03,#0d3008)}
    .g5{background:linear-gradient(160deg,#1a1500,#342900)}

    /* ── WHAT'S INSIDE ── */
    #inside { background: var(--bg); border-top: 1px solid var(--border); }
    .inside-grid {
      display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;
      margin-top: 52px;
    }
    .inside-card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 10px; padding: 28px 24px;
      display: flex; align-items: flex-start; gap: 16px;
      transition: border-color .2s, background .2s, transform .2s;
    }
    .inside-card:hover { border-color: var(--border2); background: var(--card-hov); transform: translateY(-2px); }
    .inside-icon {
      width: 42px; height: 42px; border-radius: 8px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem;
      background: var(--ic-bg, var(--teal-dim));
    }
    .inside-title {
      font-family: 'Syne', sans-serif; font-weight: 700; font-size: .9rem;
      color: var(--text); margin-bottom: 5px;
    }
    .inside-body { font-size: .85rem; color: var(--text2); line-height: 1.7; font-weight: 300; }
    .badge {
      display: inline-block; font-family: 'DM Mono', monospace;
      font-size: .58rem; letter-spacing: 1.5px; padding: 2px 8px;
      border-radius: 4px; text-transform: uppercase; margin-left: 6px; vertical-align: middle;
    }
    .b-18 { background: rgba(255,77,109,.12); color: var(--red); border: 1px solid rgba(255,77,109,.25); }
    .b-hot { background: var(--teal-dim); color: var(--teal); border: 1px solid rgba(13,242,212,.2); }

    /* ── CTA FINAL ── */
    #cta-final {
      background: var(--bg2); border-top: 1px solid var(--border);
    }
    .cta-box {
      max-width: 680px; margin: 0 auto; text-align: center; padding: 80px 40px;
    }
    .cta-av {
      width: 64px; height: 64px; border-radius: 50%; object-fit: cover;
      border: 2px solid rgba(13,242,212,.35);
      margin: 0 auto 24px; display: block;
    }
    .cta-box h2 { margin-bottom: 14px; }
    .cta-box p { color: var(--text2); font-size: .98rem; line-height: 1.8; margin-bottom: 32px; font-weight: 300; }
    .cta-meta {
      font-family: 'DM Mono', monospace; font-size: .65rem; letter-spacing: 2px;
      color: var(--text3); margin-top: 20px;
    }

    /* ── FOOTER ── */
    footer {
      position: relative; z-index: 1;
      border-top: 1px solid var(--border);
      padding: 32px 40px;
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 16px;
      background: var(--bg);
    }
    .footer-left { display: flex; align-items: center; gap: 10px; }
    .footer-av { width: 26px; height: 26px; border-radius: 50%; object-fit: cover; border: 1px solid var(--border2); }
    .footer-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: .9rem; color: var(--text2); }
    .footer-name span { color: var(--teal); }
    .footer-copy { font-family: 'DM Mono', monospace; font-size: .62rem; color: var(--text3); letter-spacing: 1px; }

    /* ── ANIM REVEAL ── */
    .reveal { opacity: 0; transform: translateY(22px); transition: opacity .6s ease, transform .6s ease; }
    .reveal.in { opacity: 1; transform: none; }

    /* ── RESPONSIVE ── */
    @media (max-width: 960px) {
      nav { padding: 0 20px; }
      .nav-ghost { display: none; }
      .wrap { padding: 0 20px; }
      #seals { padding: 20px; }
      .feat-grid { grid-template-columns: repeat(2, 1fr); }
      .games-grid { grid-template-columns: repeat(3, 1fr); }
      .inside-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 600px) {
      h1 { letter-spacing: -1px; }
      .feat-grid { grid-template-columns: 1fr; }
      .games-grid { grid-template-columns: repeat(2, 1fr); }
      .hero-stats { flex-direction: column; gap: 0; width: 100%; }
      .stat { border-right: none; border-bottom: 1px solid var(--border); }
      .stat:last-child { border-bottom: none; }
      footer { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>
<body>
<div id="cur"></div>

<!-- ══ NAV ══ -->
<nav>
  <div class="nav-left">
    <img src="avatar.jpg" class="nav-av" alt="Monolith Social" onerror="this.style.display='none'"/>
    <span class="nav-name">Monolith <span>Social</span></span>
    <div class="nav-pill"><span class="nav-dot"></span> Live</div>
  </div>
  <div class="nav-right">
    <a href="#inside" class="nav-ghost">Explore</a>
    <a href="#games" class="nav-ghost">Games</a>
    <a href="https://discord.gg/pnRCbEAtTk" target="_blank" class="nav-cta">Join Free →</a>
  </div>
</nav>

<!-- ══ HERO ══ -->
<section id="hero">
  <div class="hero-bg"></div>
  <div class="hero-vignette"></div>

  <div class="hero-inner">
    <div class="hero-av-wrap">
      <img src="avatar.jpg" class="hero-av" alt="Monolith Social" onerror="this.outerHTML='<div class=&quot;hero-av&quot; style=&quot;background:#111;display:flex;align-items:center;justify-content:center;font-size:2rem;&quot;>🪨</div>'"/>
      <span class="hero-av-live"></span>
    </div>

    <span class="eyebrow">Discord Community · Est. July 2021</span>

    <h1>
      <span class="line1">Monolith</span>
      <span class="line2">Social</span>
    </h1>

    <p class="hero-tagline">
      A cozy, a lil silly community for anime fans and gamers. Real talk, fresh memes, game nights — and a squad that actually sticks around.
    </p>

